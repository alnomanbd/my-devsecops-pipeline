# ১. লাইটওয়েট নোড ইমেজ ব্যবহার করছি
FROM node:20-alpine

# ২. কন্টেইনারের ভেতরে কাজের ডিরেক্টরি সেট করছি
WORKDIR /usr/src/app

# ৩. ডিপেন্ডেন্সি ফাইল কপি এবং ইনস্টল করছি
COPY package*.json ./
RUN npm ci --only=production

# ৪. অ্যাপ্লিকেশনের মেইন কোড কপি করছি
COPY app.js .

# ৫. পোর্ট এক্সপোজ করছি
EXPOSE 3000

# 👑 ৬. রুট ইউজার ছাড়া অ্যাপ চালানোর জন্য (সিকিউরিটি বেস্ট প্র্যাকটিস)
USER node

# ৭. অ্যাপ রান করার কমান্ড
CMD [ "node", "app.js" ]
